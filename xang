function scheduleCheck() {
  if (notifyTimer) clearInterval(notifyTimer);
  const mins = parseInt(document.getElementById('interval-min').value) || 30;
  addLog(`Lịch kiểm tra: mỗi ${mins} phút.`, 'ok');
  notifyTimer = setInterval(runAllChecks, mins * 60 * 1000);
}

// ── MAIN CHECK ROUTINE (runs all 3 alert types) ───────────────
function runAllChecks() {
  if (!notifyEnabled) return;
  FUELS.forEach((f, idx) => runChecksForFuel(idx));
}

function runChecksForFuel(idx) {
  const f      = FUELS[idx];
  const price  = getCurrentPrice(idx);
  const state  = alertState[idx];
  const high   = parseInt(document.getElementById('thresh-high').value);
  const low    = parseInt(document.getElementById('thresh-low').value);

  // ── 1. PRICE CHANGED ─────────────────────────────────────
  if (document.getElementById('alert-change').checked) {
    const minDelta = parseInt(document.getElementById('change-min-delta').value) || 200;
    if (state.lastPrice !== null) {
      const delta = price - state.lastPrice;
      if (Math.abs(delta) >= minDelta) {
        const dir   = delta > 0 ? '▲ TĂNG' : '▼ GIẢM';
        const emoji = delta > 0 ? '🔴' : '🟢';
        sendNotification(
          `${emoji} Giá xăng đã thay đổi — ${f.name}`,
          `${dir} ${fmt(Math.abs(delta))} đ\nTừ ${fmt(state.lastPrice)} → ${fmt(price)} đ/lít`,
          `change-${idx}`
        );
        addLog(`🔄 ${f.name}: giá thay đổi ${dir} ${fmt(Math.abs(delta))} đ (${fmt(state.lastPrice)} → ${fmt(price)})`, delta > 0 ? 'warn' : 'ok');
        state.surgeAlerted = false; // reset surge alert after real change
      }
    }
    state.lastPrice = price;
  }

  // ── 2. SURGE WARNING (based on prediction) ────────────────
  if (document.getElementById('alert-surge').checked) {
    const surge = detectSurge(idx);
    if (surge.detected && !state.surgeAlerted) {
      const dayStr = surge.dayIdx === 0 ? 'hôm nay' : `trong ${surge.dayIdx} ngày tới`;
      sendNotification(
        `⚡ Cảnh báo sắp biến động — ${f.name}`,
        `Dự báo ${surge.direction} khoảng ${fmt(surge.delta)} đ ${dayStr}\nGiá hiện tại: ${fmt(price)} đ/lít`,
        `surge-${idx}`
      );
      addLog(`⚡ ${f.name}: dự báo ${surge.direction} ~${fmt(surge.delta)} đ ${dayStr}`, 'warn');
      state.surgeAlerted = true;
    } else if (!surge.detected) {
      state.surgeAlerted = false; // reset when surge clears
    }
  }

  // ── 3. THRESHOLD BREACH ───────────────────────────────────
  if (document.getElementById('alert-thresh').checked) {
    if (price > high && !state.threshHighFired) {
      sendNotification(
        `🚨 Giá xăng vượt ngưỡng cao — ${f.name}`,
        `${fmt(price)} đ/lít > ngưỡng ${fmt(high)} đ/lít`,
        `thresh-high-${idx}`
      );
      addLog(`🚨 ${f.name}: vượt ngưỡng cao ${fmt(high)} đ`, 'error');
      state.threshHighFired = true;
      state.threshLowFired  = false;
    } else if (price < low && !state.threshLowFired) {
      sendNotification(
        `🟢 Giá xăng xuống dưới ngưỡng thấp — ${f.name}`,
        `${fmt(price)} đ/lít < ngưỡng ${fmt(low)} đ/lít`,
        `thresh-low-${idx}`
      );
      addLog(`✅ ${f.name}: dưới ngưỡng thấp ${fmt(low)} đ`, 'ok');
      state.threshLowFired  = true;
      state.threshHighFired = false;
    } else if (price <= high && price >= low) {
      state.threshHighFired = false;
      state.threshLowFired  = false;
    }
  }
}

// ── SIMULATE PRICE CHANGE ─────────────────────────────────────
function simulatePriceChange() {
  const idx   = currentFuelIdx;
  const state = fuelState[idx];

  // Occasionally simulate a large surge for demo purposes
  const bigSurge = Math.random() < 0.3;
  const delta = bigSurge
    ? Math.round((Math.random() > 0.5 ? 1 : -1) * (700 + Math.random() * 600) / 50) * 50
    : Math.round((Math.random() - 0.4) * 800 / 50) * 50;

  const newPrice = Math.max(10000, state.history.at(-1) + delta);
  state.history.push(newPrice);
  state.history.shift();
  state.predictions = predict(state.history);

  const label = delta >= 0 ? `+${fmt(delta)}` : fmt(delta);
  addLog(`Mô phỏng cục bộ: ${FUELS[idx].name} ${label} đ → ${fmt(newPrice)} đ/lít${bigSurge ? ' (BIẾN ĐỘNG LỚN)' : ''}`, delta > 0 ? 'warn' : 'ok');

  refreshUI();
  if (notifyEnabled) runChecksForFuel(idx);
}

// ── BOOT ──────────────────────────────────────────────────────
refreshUI();
renderMobileHelp();
addLog('Khởi tạo giao diện hoàn tất.', 'ok');
addLog('Đang đồng bộ giá thị trường trong nước...', '');
registerServiceWorker();
syncMarketPrices();

// Refresh market prices every 15 minutes.
setInterval(syncMarketPrices, 15 * 60 * 1000);
</script>
