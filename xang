  if (!('Notification' in window)) {
    addLog('Trình duyệt không hỗ trợ thông báo.', 'error');
    return;
  }

  if (isIOS && !isStandalone) {
    renderMobileHelp('<strong>Cần mở dưới dạng app:</strong> Trên iPhone/iPad, thông báo web chỉ hoạt động khi bạn Add to Home Screen và mở lại từ icon trên màn hình chính.');
    addLog('iOS yêu cầu mở app từ màn hình chính trước khi xin quyền thông báo.', 'warn');
    return;
  }

  const perm = await Notification.requestPermission();
  const warn = document.getElementById('perm-warn');
