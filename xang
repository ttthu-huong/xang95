// ── CHART ─────────────────────────────────────────────────────
function buildChart(idx) {
  const ctx = document.getElementById('chart').getContext('2d');
  const state = fuelState[idx];

  const labels30 = Array.from({length: 30}, (_, i) => {
    const d = new Date(); d.setDate(d.getDate() - 29 + i);
    return d.toLocaleDateString('vi-VN', {day:'2-digit', month:'2-digit'});
  });
  const labelsNext7 = Array.from({length: 7}, (_, i) => {
    const d = new Date(); d.setDate(d.getDate() + i + 1);
    return d.toLocaleDateString('vi-VN', {day:'2-digit', month:'2-digit'});
  });
  const allLabels = [...labels30, ...labelsNext7];

  const histData = [...state.history, ...Array(7).fill(null)];
  const predData = [...Array(29).fill(null), state.history[29], ...state.predictions];

  // Mark surge points in predictions
  const surgeThresh = parseInt(document.getElementById('surge-threshold').value) || 500;
  const surgePoints = predData.map((v, i) => {
    if (i < 30 || v === null) return null;
    const prev = predData[i-1];
    return (prev !== null && Math.abs(v - prev) >= surgeThresh) ? v : null;
  });

  if (chart) chart.destroy();

  chart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: allLabels,
      datasets: [
        {
          label: 'Lịch sử',
          data: histData,
          borderColor: '#ff6b00',
          backgroundColor: 'rgba(255,107,0,0.08)',
          borderWidth: 2,
          pointRadius: 0,
          tension: 0.3,
          fill: true,
        },
        {
          label: 'Dự báo',
          data: predData,
          borderColor: '#ffb300',
          backgroundColor: 'rgba(255,179,0,0.06)',
          borderWidth: 2,
          borderDash: [6, 3],
          pointRadius: ctx => surgePoints[ctx.dataIndex] !== null ? 7 : 3,
          pointBackgroundColor: ctx => surgePoints[ctx.dataIndex] !== null ? '#ff1744' : '#ffb300',
          pointBorderColor: ctx => surgePoints[ctx.dataIndex] !== null ? '#ff1744' : '#ffb300',
          tension: 0.3,
          fill: false,
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: {
          labels: {
            color: '#5a5a7a',
            font: { family: 'Space Mono', size: 10 },
            boxWidth: 20,
          }
        },
        tooltip: {
          backgroundColor: '#12121a',
          borderColor: '#1e1e2e',
          borderWidth: 1,
          titleColor: '#e8e8f0',
          bodyColor: '#5a5a7a',
          callbacks: {
            label: ctx => {
              if (ctx.raw === null) return null;
              const surge = surgePoints[ctx.dataIndex] !== null ? ' ⚡ BIẾN ĐỘNG LỚN' : '';
              return ` ${ctx.dataset.label}: ${fmt(ctx.raw)} đ/lít${surge}`;
            }
          }
        }
      },
      scales: {
        x: {
          grid: { color: 'rgba(255,255,255,0.03)' },
          ticks: { color: '#5a5a7a', font: { family: 'Space Mono', size: 9 }, maxTicksLimit: 10 }
        },
        y: {
          grid: { color: 'rgba(255,255,255,0.04)' },
          ticks: { color: '#5a5a7a', font: { family: 'Space Mono', size: 9 }, callback: v => fmt(v) + 'đ' }
        }
      }
    }
  });
}

// ── SELECT FUEL ───────────────────────────────────────────────
function selectFuel(idx) {
  currentFuelIdx = idx;
  document.querySelectorAll('.fuel-tab').forEach((t, i) =>
    t.classList.toggle('active', i === idx)
  );
  refreshUI();
}

function refreshUI() {
  const idx = currentFuelIdx;
  const f = FUELS[idx];
  const state = fuelState[idx];
  const cur  = state.history.at(-1);
  const prev = state.history.at(-2);
  const diff = cur - prev;
  const pct  = ((diff / prev) * 100).toFixed(2);

  document.getElementById('fuel-name-label').textContent = f.name;
  document.getElementById('hero-price').textContent = fmt(cur);

  const chg = document.getElementById('hero-change');
  if (diff > 0) {
    chg.className = 'hero-change up';
    chg.textContent = `▲ +${fmt(diff)} đ  (${pct}%)`;
  } else if (diff < 0) {
    chg.className = 'hero-change down';
    chg.textContent = `▼ ${fmt(diff)} đ  (${pct}%)`;
  } else {
    chg.className = 'hero-change flat';
    chg.textContent = `⟶ Không đổi`;
  }

  const predToday = state.predictions[0];
  const predWeek  = state.predictions[6];
  document.getElementById('stat-today').textContent = fmt(predToday);
  document.getElementById('stat-today-sub').style.color =
    predToday > cur ? 'var(--red)' : predToday < cur ? 'var(--green)' : 'var(--muted)';
  document.getElementById('stat-week').textContent = fmt(predWeek);

  const slice = state.history.slice(-30);
  const avg = slice.reduce((a,b)=>a+b,0)/slice.length;
  const vol = Math.round(Math.sqrt(slice.reduce((a,b)=>a+Math.pow(b-avg,2),0)/slice.length));
  document.getElementById('stat-vol').textContent = `±${fmt(vol)} đ`;

  const ma7  = state.history.slice(-7).reduce((a,b)=>a+b,0)/7;
  const ma14 = state.history.slice(-14).reduce((a,b)=>a+b,0)/14;
  document.getElementById('stat-trend').textContent =
    ma7 > ma14 ? '📈 Tăng' : ma7 < ma14 ? '📉 Giảm' : '➡ Đi ngang';

  // Surge banner in UI
  const surge = detectSurge(idx);
  const banner = document.getElementById('surge-banner');
  if (surge.detected) {
    banner.classList.add('active');
    banner.textContent = `⚡ CẢNH BÁO: Dự báo phát hiện biến động ${surge.direction} khoảng ${fmt(surge.delta)} đ trong ${surge.dayIdx === 0 ? 'hôm nay' : surge.dayIdx + ' ngày tới'}!`;
  } else {
    banner.classList.remove('active');
  }

  buildChart(idx);
  updateTicker();
  renderMarketMeta();
}

